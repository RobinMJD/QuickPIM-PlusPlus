{
  "name": "QuickPIM",
  "version": "1.0.0",
  "description": "Quickly view, select, group, and activate Microsoft Entra, Azure, and PIM group roles.",
  "manifest_version": 3,
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "https://graph.microsoft.com/*",
    "https://management.azure.com/*",
    "https://*.microsoft.com/*",
    "https://*.microsoftonline.com/*",
    "https://*.windows.net/*"
  ],
  "icons": {
    "16": "img/QuickPim16.png",
    "48": "img/QuickPim48.png",
    "128": "img/QuickPim128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "img/QuickPim16.png",
      "48": "img/QuickPim48.png",
      "128": "img/QuickPim128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
